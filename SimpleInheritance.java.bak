class A{
	int i,j;
	void showij(){
		System.out.println("i : "+i);
		System.out.println("j : "+j);
	}
}

class B extends A{
	int k;
	void showk(){
		System.out.println("k : "+k);
	}
	void sum(){
		System.out.println("Sum is : "+i+j+k);
	}
}

class  SimpleInheritance
{
	public static void main(String[] args) 
	{
		A superOb = new A();
		superOb.i=1;
		superOb.j=2;
		superOb.showij();
		
		B subOb = new B();
		subOb.i=1;
		subOb.j=2;
		subOb.k=3;
		subOb.showij();
		subOb.showk();
		subOb.sum();
	}
}
